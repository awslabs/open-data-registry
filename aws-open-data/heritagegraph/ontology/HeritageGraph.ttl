    skos:inScheme heritageGraph:ontology ;
    linkml:permissible_values heritageGraph:Damaged,
        heritageGraph:Good,
        heritageGraph:Restored,
        heritageGraph:Ruined .

heritageGraph:Festival a owl:Class ;
    rdfs:label "Festival" ;
    rdfs:subClassOf [ a owl:Restriction ;
