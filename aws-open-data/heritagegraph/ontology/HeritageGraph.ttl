        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:supported_by_institution ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:residence_structure ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:had_participant ],
