heritageGraph:makes_deity_present a owl:ObjectProperty ;
    rdfs:label "makes_deity_present" ;
    rdfs:range heritageGraph:Deity ;
    skos:definition "Deity made present through consecration" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:member_of_group a owl:ObjectProperty ;
    rdfs:label "member_of_group" ;
    rdfs:domain heritageGraph:Person ;
    rdfs:range heritageGraph:Guthi ;
    rdfs:subPropertyOf crm:P107i_is_current_or_former_member_of ;
    owl:inverseOf heritageGraph:has_membership ;
    skos:definition "Groups this person belongs to" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:metadata a owl:ObjectProperty ;
    rdfs:label "metadata" ;
    skos:definition "Dataset metadata" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:occurs_before a owl:ObjectProperty ;
    rdfs:label "occurs_before" ;
    rdfs:range heritageGraph:RitualEvent ;
    rdfs:subPropertyOf crm:P120_occurs_before ;
    skos:definition "Points to the next ritual in the canonical sequence." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:orcid_identifier a owl:DatatypeProperty ;
    rdfs:label "orcid_identifier" ;
    rdfs:range xsd:anyURI ;
    skos:broadMatch dct:identifier ;
    skos:definition "ORCID persistent identifier URI for a researcher or documented contributor." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:place_coordinates a owl:DatatypeProperty ;
    rdfs:label "place_coordinates" ;
    rdfs:range geo:wktLiteral ;
    rdfs:subPropertyOf geo:asWKT ;
    skos:definition "Coordinates as WKT literal" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:place_type a owl:DatatypeProperty ;
    rdfs:label "place_type" ;
    rdfs:range xsd:string ;
    skos:broadMatch crm:P2_has_type ;
    skos:definition "Type of place (city, village, region)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:publication_timespan a owl:ObjectProperty ;
    rdfs:label "publication_timespan" ;
    rdfs:range heritageGraph:TimeSpan ;
    skos:broadMatch crm:P4_has_time-span ;
    skos:definition "When source was published" ;
