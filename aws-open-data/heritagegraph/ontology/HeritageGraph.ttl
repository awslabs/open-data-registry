            owl:onProperty heritageGraph:assigned_to_deity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:DataSource ;
            owl:onProperty heritageGraph:documented_in_source ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Deity ;
            owl:onProperty heritageGraph:assigned_to_deity ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:reconciliation_status ],
        [ a owl:Restriction ;
