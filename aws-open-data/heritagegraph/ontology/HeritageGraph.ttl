            owl:onProperty heritageGraph:embodied_deity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:has_retirement_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:LivingGoddessRetirement ;
            owl:onProperty heritageGraph:has_retirement_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:ArchitecturalStructure ;
            owl:onProperty heritageGraph:residence_structure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Person ;
            owl:onProperty heritageGraph:had_participant ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:has_retirement_event ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:has_timespan ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Guthi ;
            owl:onProperty heritageGraph:supported_by_institution ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:embodied_deity ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:residence_structure ],
        crm:E4_Period ;
    skos:definition "Time-bounded role where a person embodies a deity as Living Goddess (Kumari), residing at a specific god-house and supported by religious institutions. This class captures the unique Nepali tradition of living deity embodiment in young girls selected from Buddhist Shakya/Vajracharya families." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Material a owl:Class ;
    rdfs:label "Material" ;
