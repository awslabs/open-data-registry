            owl:onProperty heritageGraph:enshrines_deity_through_event ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:has_architectural_style ],
        heritageGraph:ArchitecturalStructure ;
    owl:disjointWith heritageGraph:BuddhistMonument,
        heritageGraph:RestHouse,
        heritageGraph:WaterStructure ;
    skos:closeMatch dbo:ReligiousBuilding,
        dbo:Temple,
        schema:HinduTemple,
        schema:PlaceOfWorship,
        wikidata:Q44539 ;
    skos:definition "Sacred architectural structure legally classified as an 'Ancient Monument' under Nepal's preservation laws, characterized by deity enshrinement and ritual activation." ;
    skos:exactMatch aat:300007595 ;
    skos:inScheme heritageGraph:ontology .

