heritageGraph:HumanMadeObject a owl:Class ;
    rdfs:label "HumanMadeObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:TransferOfCustody ;
            owl:onProperty heritageGraph:has_custody_event ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:was_produced_by_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Place ;
            owl:onProperty heritageGraph:has_current_location ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:RitualEvent ;
            owl:onProperty heritageGraph:participates_in_ritual ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:has_condition_assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Production ;
            owl:onProperty heritageGraph:was_produced_by_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:DocumentationActivity ;
            owl:onProperty heritageGraph:was_documented_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:has_custody_event ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:has_current_location ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:was_documented_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:ConditionAssessment ;
            owl:onProperty heritageGraph:has_condition_assessment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:has_current_location ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:was_produced_by_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty heritageGraph:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:participates_in_ritual ],
        crm:E22_Human-Made_Object ;
    owl:disjointWith heritageGraph:Actor,
        heritageGraph:Deity,
        heritageGraph:Place,
        heritageGraph:TimeSpan ;
    skos:broadMatch edm:PhysicalThing ;
    skos:closeMatch schema:CreativeWork,
        wikidata:Q838948 ;
    skos:definition "Physical objects created by human activity" ;
    skos:exactMatch aat:300117127 ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:LivingGoddessTenure a owl:Class ;
    rdfs:label "LivingGoddessTenure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:has_timespan ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:DocumentationActivity ;
