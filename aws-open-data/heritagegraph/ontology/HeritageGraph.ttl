heritageGraph:ontology a owl:Ontology ;
    rdfs:label "HeritageGraph" ;
    dct:creator "CAIR-Nepal" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:modified "2026-06-23" ;
    dct:publisher "CAIR-Nepal" ;
    dct:title "HeritageGraph Ontology" ;
    pav:version "1.0.0" ;
    owl:imports crm:,
        crminf:,
        edm:,
        geo:,
        time:,
        prov: ;
    owl:ontologyIRI "https://cair-nepal.org/heritagegraph/ontology" ;
    owl:versionIRI <https://cair-nepal.org/heritagegraph/ontology/1.0.0> ;
    owl:versionInfo "1.0.0" ;
    skos:definition "An event-centric LinkML schema for representing Nepal cultural heritage information, fully aligned with CIDOC-CRM v7.2.1 and PROV-O. Enables provenance tracking, ritual-spatial-temporal reasoning, and multi-calendar date representation. DL expressivity: ALCIQ(D)." .

