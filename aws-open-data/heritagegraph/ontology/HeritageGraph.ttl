            owl:onProperty heritageGraph:syncretic_type ],
        crm:E13_Attribute_Assignment ;
    skos:definition "Formalizes the syncretic equivalence between divine entities across different theological frameworks. Following CIDOC CRM E13, it treats syncretism as a propositional claim with associated epistemic authority and provenance." ;
    skos:inScheme heritageGraph:ontology .

geo:wktLiteral a rdfs:Datatype ;
    owl:equivalentClass xsd:string .

heritageGraph:Abhisheka a owl:NamedIndividual,
        skos:Concept,
        heritageGraph:RitualTypeEnum ;
    rdfs:label "Abhisheka" ;
    skos:definition "Ritual bathing/anointing of deity" ;
    skos:inScheme <https://cair-nepal.org/heritagegraph/scheme/RitualTypeEnum> ;
    skos:prefLabel "Abhisheka" .

heritageGraph:Appropriation a owl:NamedIndividual,
        skos:Concept,
        heritageGraph:SyncreticTypeEnum ;
    rdfs:label "Appropriation" ;
    skos:definition "Deity borrowed from one tradition into another" ;
    skos:inScheme <https://cair-nepal.org/heritagegraph/scheme/SyncreticTypeEnum> ;
    skos:prefLabel "Appropriation" .

heritageGraph:ArchivalRecord a owl:Class ;
    rdfs:label "ArchivalRecord" ;
    rdfs:subClassOf heritageGraph:DataSource,
        rico:Record ;
    skos:broadMatch crm:E31_Document ;
    skos:definition "Government or institutional administrative record" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:ArchivalRecordSource a owl:NamedIndividual,
