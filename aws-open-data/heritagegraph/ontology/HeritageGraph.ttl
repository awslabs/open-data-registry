heritageGraph:RestHouse a owl:Class ;
    rdfs:label "RestHouse" ;
    rdfs:subClassOf heritageGraph:ArchitecturalStructure ;
    owl:disjointWith heritageGraph:WaterStructure ;
    skos:definition "Community structures for travelers and pilgrims, maintained by Guthi organizations" ;
