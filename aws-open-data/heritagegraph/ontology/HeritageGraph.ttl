heritageGraph:ritual_type a owl:ObjectProperty ;
    rdfs:label "ritual_type" ;
    rdfs:range heritageGraph:RitualTypeEnum ;
    skos:broadMatch crm:P2_has_type ;
    skos:definition "Classification of ritual (puja, jatra, consecration)" ;
