heritageGraph:schema_version a owl:DatatypeProperty ;
    rdfs:label "schema_version" ;
    skos:definition "Version of the HeritageGraph schema the dataset conforms to." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:selected_person a owl:ObjectProperty ;
    rdfs:label "selected_person" ;
    rdfs:range heritageGraph:Person ;
