heritageGraph:datacite_resource_type a owl:DatatypeProperty ;
    rdfs:label "datacite_resource_type" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf datacite:resourceType ;
    skos:definition "High-level DataCite resource type (Dataset, Text, Image, Audio, Interview)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:dataset_name a owl:DatatypeProperty ;
    rdfs:label "dataset_name" ;
    skos:definition "Human-readable name of the heritage dataset." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:dataset_version a owl:DatatypeProperty ;
    rdfs:label "dataset_version" ;
    skos:definition "Version identifier of the dataset instance (e.g. semantic version or release date)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:date_earliest a owl:DatatypeProperty ;
    rdfs:label "date_earliest" ;
    rdfs:range xsd:date ;
    rdfs:subPropertyOf crm:P82a_begin_of_the_begin ;
    skos:definition "Earliest possible date (for uncertain dates)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:date_latest a owl:DatatypeProperty ;
    rdfs:label "date_latest" ;
    rdfs:range xsd:date ;
    rdfs:subPropertyOf crm:P82b_end_of_the_end ;
    skos:definition "Latest possible date (for uncertain dates)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:date_precision a owl:ObjectProperty ;
    rdfs:label "date_precision" ;
    rdfs:range heritageGraph:DatePrecisionEnum ;
    skos:definition "The level of precision for a recorded date." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:death_timespan a owl:ObjectProperty ;
    rdfs:label "death_timespan" ;
    rdfs:range heritageGraph:TimeSpan ;
    skos:broadMatch crm:P4_has_time-span ;
    skos:definition "Person's death timespan" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:depicts_deity a owl:ObjectProperty ;
    rdfs:label "depicts_deity" ;
    rdfs:domain heritageGraph:IconographicObject ;
    rdfs:range heritageGraph:Deity ;
    rdfs:subPropertyOf crm:P62_depicts ;
    owl:inverseOf heritageGraph:is_depicted_in ;
    skos:definition "Deity depicted iconographically (not cultic presence)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:derived_from_interview a owl:ObjectProperty ;
    rdfs:label "derived_from_interview" ;
    rdfs:range heritageGraph:OralHistoryInterview ;
    skos:definition "Oral history interview event that produced this recording or transcript." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:destruction_event a owl:ObjectProperty ;
    rdfs:label "destruction_event" ;
    rdfs:range heritageGraph:DestructionEvent ;
    skos:definition "Event that destroyed this structure (if known)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:embodied_deity a owl:ObjectProperty ;
    rdfs:label "embodied_deity" ;
    rdfs:range heritageGraph:Deity ;
    rdfs:subPropertyOf crm:P14.1_in_the_role_of ;
    skos:definition "Deity role embodied by participant" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:end_place a owl:ObjectProperty ;
    rdfs:label "end_place" ;
    rdfs:range heritageGraph:Place ;
    skos:definition "Ending location of movement ritual" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:enshrined_deity a owl:ObjectProperty ;
    rdfs:label "enshrined_deity" ;
    rdfs:range heritageGraph:Deity ;
    skos:broadMatch crm:P12_occurred_in_the_presence_of ;
    skos:definition "Deity installed through enshrinement" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:enshrined_in_structure a owl:ObjectProperty ;
    rdfs:label "enshrined_in_structure" ;
    rdfs:range heritageGraph:Temple ;
    skos:broadMatch crm:P8_took_place_on_or_within ;
    skos:definition "Temple where deity was enshrined" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:epoch_date_gregorian a owl:DatatypeProperty ;
    rdfs:label "epoch_date_gregorian" ;
    rdfs:range xsd:string ;
    skos:definition "The start date of this calendar era in Gregorian ISO format." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:existence_status a owl:ObjectProperty ;
    rdfs:label "existence_status" ;
    rdfs:range heritageGraph:ExistenceStatusEnum ;
    skos:definition "Current physical status of the structure" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:generated_at_time a owl:DatatypeProperty ;
    rdfs:label "generated_at_time" ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf prov:generatedAtTime ;
    skos:definition "When this assertion was recorded (ISO 8601)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:generated_date a owl:DatatypeProperty ;
    rdfs:label "generated_date" ;
    skos:definition "Date the dataset was generated or last exported (ISO 8601)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:guthi_type a owl:ObjectProperty ;
    rdfs:label "guthi_type" ;
    rdfs:range heritageGraph:GuthiTypeEnum ;
    skos:broadMatch crm:P2_has_type ;
    skos:definition "Type of Guthi (Si, Jatra, Temple)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:has_component a owl:ObjectProperty ;
    rdfs:label "has_component" ;
    rdfs:domain heritageGraph:ArchitecturalStructure ;
    rdfs:range heritageGraph:ArchitecturalElement ;
    rdfs:subPropertyOf crm:P46_is_composed_of ;
    owl:inverseOf heritageGraph:is_component_of ;
    skos:definition "Architectural elements composing structure" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:has_condition_type a owl:ObjectProperty ;
    rdfs:label "has_condition_type" ;
    rdfs:range heritageGraph:ConditionTypeEnum ;
    skos:broadMatch crm:P2_has_type ;
    skos:definition "Categorization of the condition state" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:has_membership a owl:ObjectProperty ;
    rdfs:label "has_membership" ;
    rdfs:domain heritageGraph:Guthi ;
    rdfs:range heritageGraph:Person ;
    rdfs:subPropertyOf crm:P107_has_current_or_former_member ;
    owl:inverseOf heritageGraph:member_of_group ;
    skos:definition "Members of Guthi organization" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:initiated_tenure a owl:ObjectProperty ;
    rdfs:label "initiated_tenure" ;
    rdfs:range heritageGraph:LivingGoddessTenure ;
    skos:definition "Living Goddess tenure that was initiated by this selection event" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:institutional_affiliation a owl:DatatypeProperty ;
    rdfs:label "institutional_affiliation" ;
    rdfs:range xsd:string ;
    skos:definition "Institutional affiliation (e.g., Tribhuvan University, Nepal Heritage Society)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:is_about_deity a owl:ObjectProperty ;
    rdfs:label "is_about_deity" ;
    rdfs:range heritageGraph:Deity ;
    rdfs:subPropertyOf crm:P129_is_about ;
    skos:definition "Deity represented and ritually associated with the Murti" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:is_about_entity a owl:DatatypeProperty ;
    rdfs:label "is_about_entity" ;
    skos:broadMatch crm:P129_is_about ;
    skos:definition "Entity that this information object describes. Range intentionally left open: the LUX alignment module asserts owl:equivalentProperty with the generic crm:P129_is_about, so a narrow rdfs:range would over-constrain P129 and make sibling is_about_* sub-properties unsatisfiable under merged reasoning." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:is_about_event a owl:DatatypeProperty ;
    rdfs:label "is_about_event" ;
    skos:broadMatch crm:P129_is_about ;
    skos:definition "Event that this information object describes. Range intentionally left open (see is_about_entity): owl:equivalentProperty crm:P129_is_about in the LUX module precludes a narrow rdfs:range here." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:is_critical_for_festival a owl:DatatypeProperty ;
    rdfs:label "is_critical_for_festival" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether this ritual is essential for the festival's completion" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:is_depicted_in a owl:ObjectProperty ;
    rdfs:label "is_depicted_in" ;
    rdfs:domain heritageGraph:Deity ;
    rdfs:range heritageGraph:IconographicObject ;
    rdfs:subPropertyOf crm:P62i_is_depicted_by ;
    owl:inverseOf heritageGraph:depicts_deity ;
    skos:definition "Iconographic objects that depict this deity" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:last_known_existence_date a owl:DatatypeProperty ;
    rdfs:label "last_known_existence_date" ;
    rdfs:range xsd:date ;
    skos:definition "Latest date when this structure is documented as existing (ISO 8601)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:license a owl:DatatypeProperty ;
    rdfs:label "license" ;
    skos:definition "License under which the dataset is published (e.g. CC BY 4.0)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:local_contexts_label a owl:DatatypeProperty ;
    rdfs:label "local_contexts_label" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI of an applied Local Contexts Traditional Knowledge (TK) or Biocultural (BC) Notice or Label." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:lunar_date_tithi a owl:DatatypeProperty ;
    rdfs:label "lunar_date_tithi" ;
    rdfs:range xsd:string ;
    skos:definition "Lunar day (Tithi) for ritual timing" ;
