    owl:disjointWith heritageGraph:LivingGoddessSelection ;
    skos:broadMatch crm:E7_Activity ;
    skos:definition "Ritual or administrative event that formally ends a Living Goddess tenure, marking the person's return to secular status. Common triggers include first menstruation, injury causing blood loss, or serious illness. This event terminates the divine embodiment and restores the girl to ordinary status." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Murti a owl:Class ;
    rdfs:label "Murti" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Consecration ;
            owl:onProperty heritageGraph:consecrated_by_event ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:consecrated_by_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Deity ;
            owl:onProperty heritageGraph:is_about_deity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:consecrated_by_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:is_about_deity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:is_about_deity ],
        heritageGraph:IconographicObject ;
    skos:closeMatch wikidata:Q2594295 ;
    skos:definition "Consecrated statue of a deity, ritually activated to serve as divine presence (not merely depiction)" ;
    skos:exactMatch aat:300047090 ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:OralHistoryInterview a owl:Class ;
    rdfs:label "OralHistoryInterview" ;
    rdfs:subClassOf crm:E7_Activity,
        heritageGraph:DocumentationActivity ;
    owl:disjointWith heritageGraph:Verification ;
    skos:definition "The interaction event between a researcher and a knowledge holder (oral history fieldwork)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Technique a owl:Class ;
    rdfs:label "Technique" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:note ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:note ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:note ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:name ],
        crm:E29_Design_or_Procedure ;
    owl:disjointWith heritageGraph:Material ;
    skos:definition "Method or craft process used in production or ritual" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:archival_location a owl:DatatypeProperty ;
    rdfs:label "archival_location" ;
    rdfs:range xsd:string ;
    skos:definition "Where stored (e.g., National Museum Kathmandu, British Library, URL)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:asserted_property a owl:DatatypeProperty ;
    rdfs:label "asserted_property" ;
    rdfs:range xsd:string ;
    skos:definition "Optional property or attribute name when the assertion is structured as a property-value pair." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:asserted_value a owl:DatatypeProperty ;
    rdfs:label "asserted_value" ;
    rdfs:range xsd:string ;
    skos:definition "Optional value claimed for asserted_property when using structured property-value assertions." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:assertion_author a owl:ObjectProperty ;
    rdfs:label "assertion_author" ;
    rdfs:range heritageGraph:Actor ;
    skos:broadMatch crm:P14_carried_out_by ;
    skos:definition "The agent (scholar, priest, or tradition-bearer) making or recording the syncretic claim." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:assertion_content a owl:DatatypeProperty ;
    rdfs:label "assertion_content" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf prov:value ;
    skos:definition "The factual claim being asserted" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:asserts_about_entity a owl:ObjectProperty ;
    rdfs:label "asserts_about_entity" ;
    rdfs:range heritageGraph:AssertableEntity ;
    skos:definition "Entity that is the subject of this belief/assertion (CRMinf I2_Belief scope; not an E13 attribute assignment)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:asserts_about_event a owl:ObjectProperty ;
    rdfs:label "asserts_about_event" ;
    rdfs:range heritageGraph:RitualEvent ;
    skos:definition "Event that is the subject of this belief/assertion (CRMinf I2_Belief scope; not an E13 attribute assignment)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:assessed_condition_state a owl:ObjectProperty ;
    rdfs:label "assessed_condition_state" ;
    rdfs:range heritageGraph:ConditionState ;
    rdfs:subPropertyOf crm:P35_has_identified ;
    skos:definition "Condition state identified by the assessment" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:assessed_object a owl:ObjectProperty ;
    rdfs:label "assessed_object" ;
    rdfs:range heritageGraph:PhysicalHeritageThing ;
    rdfs:subPropertyOf crm:P34_concerned ;
    skos:definition "Object assessed for condition" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:assigned_to_deity a owl:ObjectProperty ;
    rdfs:label "assigned_to_deity" ;
    rdfs:range heritageGraph:Deity ;
    rdfs:subPropertyOf crm:P140_assigned_attribute_to ;
    skos:definition "The deity instance that is the subject of the syncretic claim." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:birth_timespan a owl:ObjectProperty ;
    rdfs:label "birth_timespan" ;
    rdfs:range heritageGraph:TimeSpan ;
    skos:broadMatch crm:P4_has_time-span ;
    skos:definition "Person's birth timespan" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:calendar_system a owl:ObjectProperty ;
    rdfs:label "calendar_system" ;
    rdfs:range heritageGraph:CalendarSystem ;
    skos:definition "Calendar system used for date representation" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:community_attribution a owl:DatatypeProperty ;
    rdfs:label "community_attribution" ;
    rdfs:range xsd:string ;
    skos:definition "Community, custodial group, or tradition-bearer attribution for the source." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:consecrated_by_event a owl:ObjectProperty ;
    rdfs:label "consecrated_by_event" ;
    rdfs:range heritageGraph:Consecration ;
    skos:definition "Consecration event that activated this murti" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:consecrated_object a owl:ObjectProperty ;
    rdfs:label "consecrated_object" ;
    rdfs:range heritageGraph:Murti ;
    skos:broadMatch crm:P11_had_participant ;
    skos:definition "Murti that participated in the consecration ritual" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:contains_structure a owl:ObjectProperty ;
    rdfs:label "contains_structure" ;
    rdfs:domain heritageGraph:Place ;
    rdfs:range heritageGraph:PhysicalHeritageThing ;
    rdfs:subPropertyOf crm:P53i_is_former_or_current_location_of ;
    owl:inverseOf heritageGraph:has_current_location ;
    skos:definition "Structures located in this place" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:curator a owl:DatatypeProperty ;
    rdfs:label "curator" ;
    skos:definition "Person or institution responsible for curating the dataset." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:custodian_type a owl:DatatypeProperty ;
    rdfs:label "custodian_type" ;
    rdfs:range xsd:string ;
    skos:broadMatch crm:P2_has_type ;
    skos:definition "Type of custodian (government, academic, community)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:data_quality_note a owl:DatatypeProperty ;
    rdfs:label "data_quality_note" ;
    rdfs:range xsd:string ;
    skos:definition "Notes on data quality, completeness, or uncertainty" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:datacite_identifier a owl:DatatypeProperty ;
    rdfs:label "datacite_identifier" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf datacite:identifier ;
    skos:definition "Persistent identifier for the source (DOI, archive ID, catalog number)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:datacite_identifier_type a owl:DatatypeProperty ;
    rdfs:label "datacite_identifier_type" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf datacite:identifierType ;
    skos:definition "Type of identifier (DOI, ISBN, Handle, LocalArchiveID)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:datacite_publisher a owl:ObjectProperty ;
    rdfs:label "datacite_publisher" ;
    rdfs:range heritageGraph:Actor ;
    rdfs:subPropertyOf datacite:publisher ;
    skos:definition "Entity responsible for making the source available" ;
