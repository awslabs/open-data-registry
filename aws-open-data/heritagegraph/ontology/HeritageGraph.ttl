heritageGraph:ChariotFestival a owl:Class ;
    rdfs:label "ChariotFestival" ;
    rdfs:subClassOf heritageGraph:Festival ;
    owl:disjointWith heritageGraph:MaskedDance ;
    skos:definition "Festival involving ceremonial chariot procession (e.g., Rato Machhindranath Jatra)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Container a owl:Class ;
    rdfs:label "Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:metadata ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:caste_groups ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:production_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:calendar_systems ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:has_architectural_style ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Guthi ;
            owl:onProperty heritageGraph:guthis ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:information_objects ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:CalendarSystem ;
            owl:onProperty heritageGraph:calendar_systems ],
