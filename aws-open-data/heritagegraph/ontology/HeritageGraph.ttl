heritageGraph:recurrence_pattern a owl:DatatypeProperty ;
    rdfs:label "recurrence_pattern" ;
    rdfs:range xsd:string ;
    skos:definition "Frequency of recurring ritual (e.g., annual, monthly)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:residence_structure a owl:ObjectProperty ;
