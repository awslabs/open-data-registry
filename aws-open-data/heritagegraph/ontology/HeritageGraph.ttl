heritageGraph:OralHistoryRecording a owl:Class ;
    rdfs:label "OralHistoryRecording" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:derived_from_interview ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:OralHistoryInterview ;
            owl:onProperty heritageGraph:derived_from_interview ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:derived_from_interview ],
        crm:E33_Linguistic_Object,
        heritageGraph:DataSource ;
    owl:disjointWith heritageGraph:ArchivalRecord ;
    skos:definition "The recording or transcript of an oral history interview." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Pokhari a owl:Class ;
    rdfs:label "Pokhari" ;
    rdfs:subClassOf heritageGraph:WaterStructure ;
    skos:definition "Pond or tank for water storage, ritual bathing, and ecological management" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Sattal a owl:Class ;
    rdfs:label "Sattal" ;
    rdfs:subClassOf heritageGraph:RestHouse ;
    owl:disjointWith heritageGraph:Dharmashala ;
    skos:definition "Multi-story rest house (3-5 floors) with ritual and social functions" ;
    skos:inScheme heritageGraph:ontology .

