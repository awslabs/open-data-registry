    skos:inScheme heritageGraph:ontology .

heritageGraph:source_citation a owl:DatatypeProperty ;
    rdfs:label "source_citation" ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf heritageGraph:note ;
    skos:definition "Formal citation of source" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:source_type a owl:ObjectProperty ;
    rdfs:label "source_type" ;
    rdfs:range heritageGraph:SourceTypeEnum ;
    skos:definition "Controlled source-type classification for provenance and epistemic filtering." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:source_url a owl:DatatypeProperty ;
    rdfs:label "source_url" ;
    rdfs:range xsd:string ;
    skos:definition "URL or digital identifier for source" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:start_place a owl:ObjectProperty ;
    rdfs:label "start_place" ;
    rdfs:range heritageGraph:Place ;
    skos:definition "Starting location of movement ritual" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:supersedes_assertion a owl:ObjectProperty ;
    rdfs:label "supersedes_assertion" ;
    rdfs:range heritageGraph:HeritageAssertion ;
    rdfs:subPropertyOf prov:wasRevisionOf ;
    skos:definition "Previous version of this assertion (if this is an update). Creates version chain: A1 → A2 → A3. Query pattern: latest assertion = one with no incoming prov:wasRevisionOf" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:syncretic_type a owl:ObjectProperty ;
    rdfs:label "syncretic_type" ;
    rdfs:range heritageGraph:SyncreticTypeEnum ;
    skos:broadMatch crm:P2_has_type ;
    skos:definition "The typological nature of the syncretism (e.g., Ontological Identity, Functional Overlap, Iconographic Similarity)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:traditional_knowledge_notice a owl:DatatypeProperty ;
    rdfs:label "traditional_knowledge_notice" ;
    rdfs:range xsd:string ;
    skos:definition "Traditional-knowledge access, attribution, or care notice (e.g., community protocol labels)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:traditional_role a owl:DatatypeProperty ;
    rdfs:label "traditional_role" ;
    rdfs:range xsd:string ;
    skos:definition "Hereditary occupation or ritual duty" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:transferred_from_actor a owl:ObjectProperty ;
    rdfs:label "transferred_from_actor" ;
    rdfs:range heritageGraph:Actor ;
    rdfs:subPropertyOf crm:P28_custody_surrendered_by ;
    skos:definition "Previous custodian" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:transferred_object a owl:ObjectProperty ;
    rdfs:label "transferred_object" ;
    rdfs:range heritageGraph:PhysicalHeritageThing ;
    rdfs:subPropertyOf crm:P30_transferred_custody_of ;
    skos:definition "Object transferred in custody event" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:transferred_to_actor a owl:ObjectProperty ;
    rdfs:label "transferred_to_actor" ;
    rdfs:range heritageGraph:Actor ;
    rdfs:subPropertyOf crm:P29_custody_received_by ;
    skos:definition "New custodian (person or group)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:transferred_to_guthi a owl:ObjectProperty ;
    rdfs:label "transferred_to_guthi" ;
    rdfs:range heritageGraph:Guthi ;
    skos:broadMatch crm:P29_custody_received_by ;
    skos:definition "New custodian (Guthi)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:used_method a owl:DatatypeProperty ;
    rdfs:label "used_method" ;
    rdfs:range xsd:string ;
    skos:definition "Documentation method used (free-text). Not mapped to crm:P33_used_specific_technique, which is an object property requiring an crm:E29 technique resource." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:verification_method a owl:DatatypeProperty ;
    rdfs:label "verification_method" ;
    rdfs:range xsd:string ;
    skos:definition "Method used for verification (cross-check, expert review, field visit)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:year_offset_from_gregorian a owl:DatatypeProperty ;
    rdfs:label "year_offset_from_gregorian" ;
    rdfs:range xsd:integer ;
    skos:definition "Mathematical offset to convert to Common Era (e.g., +57 for BS)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:HeritageEvent a owl:Class ;
    rdfs:label "HeritageEvent" ;
    owl:unionOf ( heritageGraph:Production heritageGraph:RitualEvent heritageGraph:TransferOfCustody heritageGraph:ConditionAssessment heritageGraph:DocumentationActivity heritageGraph:HistoricalEvent heritageGraph:DestructionEvent ) ;
    skos:definition "Union of heritage event classes used for actor participation and temporal reasoning." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:InformationObject a owl:Class ;
    rdfs:label "InformationObject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:source_language ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:source_language ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:is_about_entity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:is_about_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:was_documented_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:source_language ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:created_by_documentation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:is_about_event ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:is_about_event ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:created_by_documentation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:is_about_entity ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:DocumentationActivity ;
            owl:onProperty heritageGraph:was_documented_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:DocumentationActivity ;
            owl:onProperty heritageGraph:created_by_documentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:is_about_entity ],
        heritageGraph:DataSource ;
    skos:definition "A recorded piece of information about heritage" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:created_by_documentation a owl:ObjectProperty ;
    rdfs:label "created_by_documentation" ;
    rdfs:domain heritageGraph:InformationObject ;
    rdfs:range heritageGraph:DocumentationActivity ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    owl:inverseOf heritageGraph:produced_information_object ;
    skos:definition "Documentation activity that produced this information object" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:documented_in_source a owl:ObjectProperty ;
    rdfs:label "documented_in_source" ;
    rdfs:range heritageGraph:DataSource ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    skos:definition "Sources that influenced or documented this entity (distinct from assertion derivation via was_derived_from_source)." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:ended_tenure_of a owl:ObjectProperty ;
    rdfs:label "ended_tenure_of" ;
    rdfs:domain heritageGraph:LivingGoddessRetirement ;
    rdfs:range heritageGraph:LivingGoddessTenure ;
    owl:inverseOf heritageGraph:has_retirement_event ;
    skos:definition "Points from a LivingGoddessRetirement event to the tenure that it terminated. Enables reconstruction of complete Living Goddess lifecycle." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:has_condition_assessment a owl:ObjectProperty ;
    rdfs:label "has_condition_assessment" ;
    rdfs:range heritageGraph:ConditionAssessment ;
    rdfs:subPropertyOf crm:P34i_was_assessed_by ;
    skos:definition "Condition assessment events for this structure" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:has_retirement_event a owl:ObjectProperty ;
    rdfs:label "has_retirement_event" ;
    rdfs:domain heritageGraph:LivingGoddessTenure ;
    rdfs:range heritageGraph:LivingGoddessRetirement ;
    owl:inverseOf heritageGraph:ended_tenure_of ;
    skos:definition "Retirement event that ended this Living Goddess tenure" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:is_component_of a owl:ObjectProperty ;
    rdfs:label "is_component_of" ;
    rdfs:domain heritageGraph:ArchitecturalElement ;
    rdfs:range heritageGraph:ArchitecturalStructure ;
    rdfs:subPropertyOf crm:P46i_forms_part_of ;
    owl:inverseOf heritageGraph:has_component ;
    skos:definition "Larger structure that this element is part of" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:is_part_of_festival a owl:ObjectProperty ;
    rdfs:label "is_part_of_festival" ;
    rdfs:domain heritageGraph:RitualEvent ;
    rdfs:range heritageGraph:Festival ;
    rdfs:subPropertyOf crm:P9i_forms_part_of ;
    owl:inverseOf heritageGraph:includes_ritual_event ;
    skos:definition "Larger festival this ritual is part of" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:occurs_after a owl:ObjectProperty ;
    rdfs:label "occurs_after" ;
    rdfs:range heritageGraph:RitualEvent ;
    rdfs:subPropertyOf crm:P120i_is_occurred_before_by ;
    skos:definition "Points to the prerequisite ritual." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:participates_in_ritual a owl:ObjectProperty ;
    rdfs:label "participates_in_ritual" ;
    rdfs:range heritageGraph:RitualEvent ;
    skos:broadMatch crm:P12i_was_present_at ;
    skos:definition "Rituals in which this structure participates" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:produced_information_object a owl:ObjectProperty ;
    rdfs:label "produced_information_object" ;
    rdfs:domain heritageGraph:DocumentationActivity ;
    rdfs:range heritageGraph:InformationObject ;
    rdfs:subPropertyOf prov:generated ;
    owl:inverseOf heritageGraph:created_by_documentation ;
    skos:definition "Information object (record, document) produced by documentation" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:produced_object a owl:ObjectProperty ;
    rdfs:label "produced_object" ;
    rdfs:domain heritageGraph:Production ;
    rdfs:range heritageGraph:PhysicalHeritageThing ;
    rdfs:subPropertyOf crm:P108_has_produced ;
    owl:inverseOf heritageGraph:was_produced_by_event ;
    skos:definition "Object produced by this production event" ;
    skos:inScheme heritageGraph:ontology .

<https://cair-nepal.org/heritagegraph/scheme/ConditionTypeEnum> a skos:ConceptScheme ;
