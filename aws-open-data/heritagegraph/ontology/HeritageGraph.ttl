heritageGraph:ConditionTypeEnum a owl:Class ;
    rdfs:label "ConditionTypeEnum" ;
    owl:oneOf ( heritageGraph:Good heritageGraph:Damaged heritageGraph:Ruined heritageGraph:Restored ) ;
