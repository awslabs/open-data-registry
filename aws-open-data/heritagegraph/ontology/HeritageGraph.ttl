            owl:onProperty heritageGraph:note ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:name ],
        crm:E57_Material ;
    skos:definition "Physical substance used in construction or crafting" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:ReligiousTradition a owl:Class ;
    rdfs:label "ReligiousTradition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:name ],
