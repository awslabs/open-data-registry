heritageGraph:DhungeDhara a owl:Class ;
    rdfs:label "DhungeDhara" ;
    rdfs:subClassOf heritageGraph:WaterStructure ;
    owl:disjointWith heritageGraph:Pokhari ;
    skos:definition "Stone spout (hiti) with carved imagery, used for ritual bathing and daily water supply" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:FieldSurveyActivity a owl:Class ;
    rdfs:label "FieldSurveyActivity" ;
    rdfs:subClassOf crmsci:S4_Observation,
        heritageGraph:DocumentationActivity ;
    owl:disjointWith heritageGraph:OralHistoryInterview,
        heritageGraph:Verification ;
    skos:definition "The activity of measuring, photographing, or assessing a site in person." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:FieldSurveyDataset a owl:Class ;
    rdfs:label "FieldSurveyDataset" ;
    rdfs:subClassOf crm:E31_Document,
        heritageGraph:DataSource ;
    owl:disjointWith heritageGraph:ArchivalRecord,
        heritageGraph:OralHistoryRecording ;
    skos:definition "The structured data or report resulting from a field survey." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Pati a owl:Class ;
    rdfs:label "Pati" ;
    rdfs:subClassOf heritageGraph:RestHouse ;
    owl:disjointWith heritageGraph:Dharmashala,
        heritageGraph:Sattal ;
    skos:definition "Open-air pavilion for resting travelers" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Paubha a owl:Class ;
    rdfs:label "Paubha" ;
    rdfs:subClassOf heritageGraph:IconographicObject ;
    owl:disjointWith heritageGraph:Murti ;
    skos:broadMatch aat:300033666 ;
    skos:closeMatch wikidata:Q130993 ;
    skos:definition "Traditional Newari scroll painting (thangka) with mandala and deity iconography" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Stupa a owl:Class ;
    rdfs:label "Stupa" ;
    rdfs:subClassOf heritageGraph:BuddhistMonument ;
    owl:disjointWith heritageGraph:Chaitya ;
    skos:definition "Buddhist dome-shaped reliquary shrine (e.g., Boudhanath, Swayambhunath)" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:occurred_after a owl:ObjectProperty ;
    rdfs:label "occurred_after" ;
    rdfs:range heritageGraph:RitualEvent ;
    rdfs:subPropertyOf heritageGraph:occurs_after ;
    skos:definition "LUX-alignment alias of occurs_after (the LUX bridge module grounds occurred_after in crm:P183i_starts_after_the_end_of). Declared in the core so that bridge reference resolves; sub-property of occurs_after." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:Chaitya a owl:Class ;
    rdfs:label "Chaitya" ;
    rdfs:subClassOf heritageGraph:BuddhistMonument ;
    skos:definition "Buddhist votive shrine or prayer hall" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:DataCustodian a owl:Class ;
    rdfs:label "DataCustodian" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:custodian_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:note ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:note ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:custodian_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:custodian_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:note ],
        prov:Agent ;
    skos:definition "Institution or person currently stewarding heritage data" ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:LivingGoddessSelection a owl:Class ;
    rdfs:label "LivingGoddessSelection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:was_documented_by ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:took_place_at ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:TimeSpan ;
            owl:onProperty heritageGraph:has_timespan ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:has_timespan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:initiated_tenure ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:has_provenance_assertion ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:selection_criteria_met ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:is_critical_for_festival ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:took_place_at ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:selection_criteria_met ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ owl:unionOf ( heritageGraph:Guthi heritageGraph:CasteGroup ) ] ;
            owl:onProperty heritageGraph:performed_by_group ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Person ;
            owl:onProperty heritageGraph:selected_person ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:performed_by_group ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:DocumentationActivity ;
            owl:onProperty heritageGraph:was_documented_by ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Place ;
            owl:onProperty heritageGraph:took_place_at ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty heritageGraph:carried_out_by ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:selected_person ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:selected_person ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:is_critical_for_festival ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:HeritageAssertion ;
            owl:onProperty heritageGraph:has_provenance_assertion ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:LivingGoddessTenure ;
            owl:onProperty heritageGraph:initiated_tenure ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:has_timespan ],
        [ a owl:Restriction ;
            owl:allValuesFrom heritageGraph:Actor ;
            owl:onProperty heritageGraph:carried_out_by ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:initiated_tenure ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty heritageGraph:is_critical_for_festival ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty heritageGraph:name ],
        heritageGraph:RitualEvent ;
    skos:broadMatch crm:E7_Activity ;
    skos:definition "Tantric ritual process of selecting a new Living Goddess from eligible candidates. Involves examination of 32 auspicious physical marks (lakshana), horoscope matching with the city and ruling authority, and tests of fearlessness (e.g., remaining calm among buffalo heads and masked dancers in darkness). Performed by committee of Vajracharya priests, royal priest (Raj Jyotish), and astrologer." ;
    skos:inScheme heritageGraph:ontology .

heritageGraph:MaskedDance a owl:Class ;
    rdfs:label "MaskedDance" ;
    rdfs:subClassOf heritageGraph:Festival ;
    skos:definition "Festival featuring masked dancers embodying deities (e.g., Kartik Naach)" ;
    skos:inScheme heritageGraph:ontology .

