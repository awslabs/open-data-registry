            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path crm:P3_has_note ] ;
    sh:targetClass time:Calendar .

heritageGraph:Consecration a sh:NodeShape ;
    sh:closed true ;
    sh:description "Ritual event that transforms an object into a sacred vessel (e.g., Prana Pratistha for Murti)" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity understood to be manifest through this ritual without equating person and deity identity." ;
