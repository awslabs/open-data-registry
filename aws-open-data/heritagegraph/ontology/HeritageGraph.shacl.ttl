            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path crm:P9i_forms_part_of ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Ritual occurs at specific temple or monument" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path crm:P8_took_place_on_or_within ],
        [ sh:class crm:E53_Place ;
            sh:description "Ending location of movement ritual" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path heritageGraph:end_place ] ;
    sh:targetClass heritageGraph:Consecration .

heritageGraph:HeritageEvent a sh:NodeShape ;
    sh:closed true ;
    sh:description "Union of heritage event classes used for actor participation and temporal reasoning." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass heritageGraph:HeritageEvent .

crm:E55_Type a sh:NodeShape ;
