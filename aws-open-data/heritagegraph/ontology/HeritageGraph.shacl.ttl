            sh:order 1 ;
            sh:path heritageGraph:selected_person ],
        [ sh:class crm:E39_Actor ;
            sh:description "Actor(s) who performed this event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P14_carried_out_by ],
        [ sh:datatype xsd:string ;
