@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix crminf: <http://www.cidoc-crm.org/extensions/crminf/> .
@prefix crmsci: <http://www.cidoc-crm.org/extensions/crmsci/> .
@prefix datacite: <http://purl.org/spar/datacite/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix heritageGraph: <https://cair-nepal.org/heritagegraph/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

crm:E22_Human-Made_Object a sh:NodeShape ;
    sh:closed true ;
    sh:description "Physical objects created by human activity" ;
    sh:ignoredProperties ( crm:P3_has_note heritageGraph:has_provenance_assertion rdf:type prov:wasInfluencedBy heritageGraph:destruction_event heritageGraph:consecrated_by_event heritageGraph:used_by crm:P46_is_composed_of heritageGraph:existence_status crm:P129_is_about crm:P62_depicts heritageGraph:hypothesized_location heritageGraph:enshrines_deity_through_event heritageGraph:last_known_existence_date heritageGraph:has_architectural_style ) ;
    sh:property [ sh:class crm:E14_Condition_Assessment ;
            sh:description "Condition assessment events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P34i_was_assessed_by ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique URI identifier" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dct:identifier ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals in which this structure participates" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path heritageGraph:participates_in_ritual ],
        [ sh:class crm:E53_Place ;
            sh:description "Current location of object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P55_has_current_location ],
        [ sh:class crm:E12_Production ;
            sh:description "Event that created this object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P108i_was_produced_by ],
        [ sh:class crm:E10_Transfer_of_Custody ;
            sh:description "Custody transfer events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path crm:P30i_custody_transferred_through ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass crm:E22_Human-Made_Object .

crm:E31_Document a sh:NodeShape ;
    sh:closed true ;
    sh:description "The structured data or report resulting from a field survey." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Persistent identifier for the source (DOI, archive ID, catalog number)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path datacite:identifier ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI of an applied Local Contexts Traditional Knowledge (TK) or Biocultural (BC) Notice or Label." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path heritageGraph:local_contexts_label ],
        [ sh:description "Controlled source-type classification for provenance and epistemic filtering." ;
            sh:in ( heritageGraph:OralHistory heritageGraph:Inscription heritageGraph:FieldSurvey heritageGraph:ArchivalRecordSource heritageGraph:PublishedScholarship heritageGraph:CommunityNarrative heritageGraph:RitualProtocol ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path heritageGraph:source_type ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "When source was published" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path heritageGraph:publication_timespan ],
        [ sh:datatype xsd:string ;
            sh:description "URL or digital identifier for source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:source_url ],
        [ sh:class crm:E39_Actor ;
            sh:description "Entity responsible for making the source available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path datacite:publisher ],
        [ sh:datatype xsd:string ;
            sh:description "Type of identifier (DOI, ISBN, Handle, LocalArchiveID)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path datacite:identifierType ],
        [ sh:description "Epistemic standing of a source or assertion (scholarly, community, priestly, uncertain)." ;
            sh:in ( heritageGraph:Scholarly heritageGraph:Community heritageGraph:Priestly heritageGraph:State heritageGraph:SyncreticTradition heritageGraph:Uncertain ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path heritageGraph:epistemic_stance ],
        [ sh:datatype xsd:string ;
            sh:description "Formal citation of source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path heritageGraph:source_citation ],
        [ sh:datatype xsd:string ;
            sh:description "Community, custodial group, or tradition-bearer attribution for the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path heritageGraph:community_attribution ],
        [ sh:datatype xsd:string ;
            sh:description "Traditional-knowledge access, attribution, or care notice (e.g., community protocol labels)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path heritageGraph:traditional_knowledge_notice ],
        [ sh:datatype xsd:string ;
            sh:description "Language of the source material" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path crm:P72_has_language ],
        [ sh:class crm:E39_Actor ;
            sh:description "Person or organization primarily responsible for creating the source" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path datacite:creator ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "High-level DataCite resource type (Dataset, Text, Image, Audio, Interview)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path datacite:resourceType ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Where stored (e.g., National Museum Kathmandu, British Library, URL)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path heritageGraph:archival_location ] ;
    sh:targetClass crm:E31_Document .

crm:E33_Linguistic_Object a sh:NodeShape ;
    sh:closed true ;
    sh:description "The recording or transcript of an oral history interview." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E39_Actor ;
            sh:description "Person or organization primarily responsible for creating the source" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path datacite:creator ],
        [ sh:description "Controlled source-type classification for provenance and epistemic filtering." ;
            sh:in ( heritageGraph:OralHistory heritageGraph:Inscription heritageGraph:FieldSurvey heritageGraph:ArchivalRecordSource heritageGraph:PublishedScholarship heritageGraph:CommunityNarrative heritageGraph:RitualProtocol ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path heritageGraph:source_type ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path crm:P3_has_note ],
        [ sh:class crm:E7_Activity ;
            sh:description "Oral history interview event that produced this recording or transcript." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path heritageGraph:derived_from_interview ],
        [ sh:datatype xsd:string ;
            sh:description "Formal citation of source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:source_citation ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI of an applied Local Contexts Traditional Knowledge (TK) or Biocultural (BC) Notice or Label." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path heritageGraph:local_contexts_label ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "When source was published" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:publication_timespan ],
        [ sh:datatype xsd:string ;
            sh:description "Type of identifier (DOI, ISBN, Handle, LocalArchiveID)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path datacite:identifierType ],
        [ sh:datatype xsd:string ;
            sh:description "URL or digital identifier for source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path heritageGraph:source_url ],
        [ sh:datatype xsd:string ;
            sh:description "Persistent identifier for the source (DOI, archive ID, catalog number)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path datacite:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Where stored (e.g., National Museum Kathmandu, British Library, URL)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path heritageGraph:archival_location ],
        [ sh:datatype xsd:string ;
            sh:description "High-level DataCite resource type (Dataset, Text, Image, Audio, Interview)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path datacite:resourceType ],
        [ sh:datatype xsd:string ;
            sh:description "Language of the source material" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path crm:P72_has_language ],
        [ sh:datatype xsd:string ;
            sh:description "Community, custodial group, or tradition-bearer attribution for the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path heritageGraph:community_attribution ],
        [ sh:class crm:E39_Actor ;
            sh:description "Entity responsible for making the source available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path datacite:publisher ],
        [ sh:datatype xsd:string ;
            sh:description "Traditional-knowledge access, attribution, or care notice (e.g., community protocol labels)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path heritageGraph:traditional_knowledge_notice ],
        [ sh:description "Epistemic standing of a source or assertion (scholarly, community, priestly, uncertain)." ;
            sh:in ( heritageGraph:Scholarly heritageGraph:Community heritageGraph:Priestly heritageGraph:State heritageGraph:SyncreticTradition heritageGraph:Uncertain ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path heritageGraph:epistemic_stance ] ;
    sh:targetClass crm:E33_Linguistic_Object .

crm:E5_Event a sh:NodeShape ;
    sh:closed true ;
    sh:description "Major event affecting heritage structures or ritual life (earthquake, epidemic, political transition, fire, flood)." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E53_Place ;
            sh:description "Place where event occurred" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P7_took_place_at ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Component rituals of festival" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P9_consists_of ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class heritageGraph:ArchitecturalStructure ;
            sh:description "Heritage structures affected by or present during this historical event" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path crm:P12_occurred_in_the_presence_of ] ;
    sh:targetClass crm:E5_Event .

crmsci:S4_Observation a sh:NodeShape ;
    sh:closed true ;
    sh:description "The activity of measuring, photographing, or assessing a site in person." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Event documented by this activity (documentation subject, not E13 assignment target)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path heritageGraph:subject_event ],
        [ sh:datatype xsd:string ;
            sh:description "Documentation method used (free-text). Not mapped to crm:P33_used_specific_technique, which is an object property requiring an crm:E29 technique resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path heritageGraph:used_method ],
        [ sh:class crm:E21_Person ;
            sh:description "Agent who performed documentation" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path prov:wasAssociatedWith ],
        [ sh:datatype xsd:string ;
            sh:description "Equipment used in documentation (free-text). Not mapped to crm:P16_used_specific_object, which is an object property requiring an crm:E70 thing resource." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path heritageGraph:used_equipment ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Heritage entity documented by this activity (documentation subject, not E13 assignment target)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:subject_entity ],
        [ sh:class crminf:I2_Belief ;
            sh:description "Assertions generated by documentation activity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:generated_assertion ],
        [ sh:class heritageGraph:InformationObject ;
            sh:description "Information object (record, document) produced by documentation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path prov:generated ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path crm:P4_has_time-span ] ;
    sh:targetClass crmsci:S4_Observation .

heritageGraph:ArchivalRecord a sh:NodeShape ;
    sh:closed true ;
    sh:description "Government or institutional administrative record" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E39_Actor ;
            sh:description "Person or organization primarily responsible for creating the source" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path datacite:creator ],
        [ sh:datatype xsd:string ;
            sh:description "Traditional-knowledge access, attribution, or care notice (e.g., community protocol labels)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path heritageGraph:traditional_knowledge_notice ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "High-level DataCite resource type (Dataset, Text, Image, Audio, Interview)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path datacite:resourceType ],
        [ sh:class crm:E39_Actor ;
            sh:description "Entity responsible for making the source available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path datacite:publisher ],
        [ sh:datatype xsd:string ;
            sh:description "Formal citation of source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path heritageGraph:source_citation ],
        [ sh:description "Epistemic standing of a source or assertion (scholarly, community, priestly, uncertain)." ;
            sh:in ( heritageGraph:Scholarly heritageGraph:Community heritageGraph:Priestly heritageGraph:State heritageGraph:SyncreticTradition heritageGraph:Uncertain ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path heritageGraph:epistemic_stance ],
        [ sh:datatype xsd:string ;
            sh:description "Type of identifier (DOI, ISBN, Handle, LocalArchiveID)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path datacite:identifierType ],
        [ sh:datatype xsd:string ;
            sh:description "Community, custodial group, or tradition-bearer attribution for the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path heritageGraph:community_attribution ],
        [ sh:datatype xsd:string ;
            sh:description "URL or digital identifier for source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:source_url ],
        [ sh:description "Controlled source-type classification for provenance and epistemic filtering." ;
            sh:in ( heritageGraph:OralHistory heritageGraph:Inscription heritageGraph:FieldSurvey heritageGraph:ArchivalRecordSource heritageGraph:PublishedScholarship heritageGraph:CommunityNarrative heritageGraph:RitualProtocol ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path heritageGraph:source_type ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI of an applied Local Contexts Traditional Knowledge (TK) or Biocultural (BC) Notice or Label." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path heritageGraph:local_contexts_label ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "When source was published" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path heritageGraph:publication_timespan ],
        [ sh:datatype xsd:string ;
            sh:description "Where stored (e.g., National Museum Kathmandu, British Library, URL)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path heritageGraph:archival_location ],
        [ sh:datatype xsd:string ;
            sh:description "Language of the source material" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path crm:P72_has_language ],
        [ sh:datatype xsd:string ;
            sh:description "Persistent identifier for the source (DOI, archive ID, catalog number)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path datacite:identifier ] ;
    sh:targetClass heritageGraph:ArchivalRecord .

heritageGraph:BuddhistMonument a sh:NodeShape ;
    sh:closed true ;
    sh:description "Buddhist sacred structure (Stupa, Chaitya) with circumambulation and ritual activation patterns" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E10_Transfer_of_Custody ;
            sh:description "Custody transfer events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path crm:P30i_custody_transferred_through ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique URI identifier" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dct:identifier ],
        [ sh:class crm:E53_Place ;
            sh:description "Current location of object or structure" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P55_has_current_location ],
        [ sh:class crm:E12_Production ;
            sh:description "Event that created this object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P108i_was_produced_by ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class crm:E25_Architectural_Element ;
            sh:description "Architectural elements composing structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P46_is_composed_of ],
        [ sh:class crm:E53_Place ;
            sh:description "Possible locations if the structure is lost" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path heritageGraph:hypothesized_location ],
        [ sh:class crm:E6_Destruction ;
            sh:description "Event that destroyed this structure (if known)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path heritageGraph:destruction_event ],
        [ sh:class crm:E14_Condition_Assessment ;
            sh:description "Condition assessment events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P34i_was_assessed_by ],
        [ sh:datatype xsd:date ;
            sh:description "Latest date when this structure is documented as existing (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:last_known_existence_date ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:description "Architectural style classification" ;
            sh:in ( heritageGraph:Pagoda heritageGraph:Shikhara heritageGraph:Dome heritageGraph:ChaityaStyle heritageGraph:StupaStyle ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path heritageGraph:has_architectural_style ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals in which this structure participates" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path heritageGraph:participates_in_ritual ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:description "Current physical status of the structure" ;
            sh:in ( heritageGraph:Extant heritageGraph:PartiallyExtant heritageGraph:Destroyed heritageGraph:Lost heritageGraph:Hypothetical heritageGraph:Unknown ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
