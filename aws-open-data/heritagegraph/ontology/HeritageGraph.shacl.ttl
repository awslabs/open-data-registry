crm:E13_Attribute_Assignment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Formalizes the syncretic equivalence between divine entities across different theological frameworks. Following CIDOC CRM E13, it treats syncretism as a propositional claim with associated epistemic authority and provenance." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The typological nature of the syncretism (e.g., Ontological Identity, Functional Overlap, Iconographic Similarity)." ;
            sh:in ( heritageGraph:Equivalence heritageGraph:Appropriation heritageGraph:Fusion heritageGraph:Historical ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path heritageGraph:syncretic_type ],
        [ sh:class crm:E39_Actor ;
            sh:description "The agent (scholar, priest, or tradition-bearer) making or recording the syncretic claim." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path heritageGraph:assertion_author ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:datatype xsd:float ;
            sh:description "Reliability score for assertion (0.0-1.0)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path heritageGraph:confidence_score ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path crm:P4_has_time-span ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:DataSource ;
            sh:description "Source(s) from which this assertion was derived" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype xsd:string ;
            sh:description "Status of multi-source reconciliation (confirmed, conflicting, unverified)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path heritageGraph:reconciliation_status ],
        [ sh:class heritageGraph:DataSource ;
            sh:description "Sources that influenced or documented this entity (distinct from assertion derivation via was_derived_from_source)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path prov:wasInfluencedBy ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "The deity instance that is the subject of the syncretic claim." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P140_assigned_attribute_to ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "The deity or sacred figure being identified as equivalent to the primary deity." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P141_assigned ] ;
    sh:targetClass crm:E13_Attribute_Assignment .

crm:E1_CRM_Entity a sh:NodeShape ;
    sh:closed true ;
    sh:description "Any entity that can be the subject of a heritage assertion" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass crm:E1_CRM_Entity .

crm:E29_Design_or_Procedure a sh:NodeShape ;
    sh:closed true ;
    sh:description "Method or craft process used in production or ritual" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ] ;
    sh:targetClass crm:E29_Design_or_Procedure .

crm:E3_Condition_State a sh:NodeShape ;
    sh:closed true ;
    sh:description "A physical condition state of a heritage object" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:description "Categorization of the condition state" ;
            sh:in ( heritageGraph:Good heritageGraph:Damaged heritageGraph:Ruined heritageGraph:Restored ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path heritageGraph:has_condition_type ] ;
    sh:targetClass crm:E3_Condition_State .

crm:E7_Activity a sh:NodeShape ;
    sh:closed true ;
    sh:description "The interaction event between a researcher and a knowledge holder (oral history fieldwork)." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Heritage entity documented by this activity (documentation subject, not E13 assignment target)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:subject_entity ],
        [ sh:class crminf:I2_Belief ;
            sh:description "Assertions generated by documentation activity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:generated_assertion ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path crm:P4_has_time-span ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Equipment used in documentation (free-text). Not mapped to crm:P16_used_specific_object, which is an object property requiring an crm:E70 thing resource." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path heritageGraph:used_equipment ],
        [ sh:datatype xsd:string ;
            sh:description "Documentation method used (free-text). Not mapped to crm:P33_used_specific_technique, which is an object property requiring an crm:E29 technique resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path heritageGraph:used_method ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Event documented by this activity (documentation subject, not E13 assignment target)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path heritageGraph:subject_event ],
        [ sh:class heritageGraph:InformationObject ;
            sh:description "Information object (record, document) produced by documentation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path prov:generated ],
        [ sh:class crm:E21_Person ;
            sh:description "Agent who performed documentation" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path prov:wasAssociatedWith ] ;
    sh:targetClass crm:E7_Activity .

prov:Agent a sh:NodeShape ;
    sh:closed true ;
    sh:description "Institution or person currently stewarding heritage data" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Type of custodian (government, academic, community)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path heritageGraph:custodian_type ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ] ;
    sh:targetClass prov:Agent .

heritageGraph:IconographicObject a sh:NodeShape ;
    sh:closed true ;
    sh:description "Sacred visual art objects that depict or embody deities through iconographic conventions" ;
    sh:ignoredProperties ( heritageGraph:consecrated_by_event rdf:type crm:P129_is_about ) ;
    sh:property [ sh:class crm:E12_Production ;
            sh:description "Event that created this object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P108i_was_produced_by ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity depicted iconographically (not cultic presence)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P62_depicts ],
        [ sh:class crm:E14_Condition_Assessment ;
            sh:description "Condition assessment events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path crm:P34i_was_assessed_by ],
        [ sh:class crm:E53_Place ;
            sh:description "Current location of object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P55_has_current_location ],
        [ sh:class crm:E10_Transfer_of_Custody ;
            sh:description "Custody transfer events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path crm:P30i_custody_transferred_through ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals in which this structure participates" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path heritageGraph:participates_in_ritual ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique URI identifier" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dct:identifier ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class crm:E39_Actor ;
            sh:description "Actor(s) who use, handle, or are responsible for this object in ritual contexts" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path heritageGraph:used_by ] ;
    sh:targetClass heritageGraph:IconographicObject .

heritageGraph:LivingGoddessRetirement a sh:NodeShape ;
    sh:closed true ;
    sh:description "Ritual or administrative event that formally ends a Living Goddess tenure, marking the person's return to secular status. Common triggers include first menstruation, injury causing blood loss, or serious illness. This event terminates the divine embodiment and restores the girl to ordinary status." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Ritual occurs at specific temple or monument" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path crm:P8_took_place_on_or_within ],
        [ sh:class heritageGraph:Guthi ;
            sh:description "Guthi organization managing this structure or ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path heritageGraph:managed_by_guthi ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "When the retirement occurred" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class crm:E53_Place ;
            sh:description "Where the retirement ceremony occurred" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path crm:P7_took_place_at ],
        [ sh:datatype xsd:string ;
            sh:description "Lunar day (Tithi) for ritual timing" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path heritageGraph:lunar_date_tithi ],
        [ sh:class crm:E53_Place ;
            sh:description "Ordered list of places visited during movement ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path heritageGraph:route_places ],
        [ sh:datatype xsd:string ;
            sh:description "Name of retirement event" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Text description of the procession route" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path heritageGraph:route_description ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity invoked or made present through ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path heritageGraph:invokes_deity ],
        [ sh:description "Classification of ritual (puja, jatra, consecration)" ;
            sh:in ( heritageGraph:NityaPuja heritageGraph:NaimittikaPuja heritageGraph:KamyaPuja heritageGraph:Abhisheka heritageGraph:Homa heritageGraph:Bhajan heritageGraph:Yagna heritageGraph:Vrata heritageGraph:Jatra heritageGraph:ChariotProcession heritageGraph:MaskedPerformance heritageGraph:RitualConsecration heritageGraph:ProcessionRitual heritageGraph:InstallationRitual heritageGraph:DeinstallationRitual heritageGraph:ReturningRitual heritageGraph:Circumambulation heritageGraph:RelicTour heritageGraph:ProcessionalMovement ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path heritageGraph:ritual_type ],
        [ sh:class crm:E53_Place ;
            sh:description "Starting location of movement ritual" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path heritageGraph:start_place ],
        [ sh:class crm:E53_Place ;
            sh:description "Ending location of movement ritual" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path heritageGraph:end_place ],
        [ sh:class crm:E21_Person ;
            sh:description "Priests or officials who performed the retirement ritual" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path crm:P14_carried_out_by ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Points to the next ritual in the canonical sequence." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path crm:P120_occurs_before ],
        [ sh:class crm:E57_Material ;
            sh:description "Ephemeral materials consumed during the ritual (e.g., oil, rice)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path crm:P125_used_object_of_type ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Points to the prerequisite ritual." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path crm:P120i_is_occurred_before_by ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:description "Group (Guthi, caste) responsible for ritual" ;
            sh:or ( [ sh:class heritageGraph:Guthi ] [ sh:class heritageGraph:CasteGroup ] ) ;
            sh:order 5 ;
            sh:path heritageGraph:performed_by_group ],
        [ sh:class crm:E4_Period ;
            sh:description "The Living Goddess tenure that this event terminated" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path heritageGraph:ended_tenure_of ],
        [ sh:datatype xsd:string ;
            sh:description "Frequency of recurring ritual (e.g., annual, monthly)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path heritageGraph:recurrence_pattern ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity understood to be manifest through this ritual without equating person and deity identity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path heritageGraph:manifests_divine_presence ],
        [ sh:class crminf:I2_Belief ;
            sh:description "All factual claims about this structure with full provenance" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:has_provenance_assertion ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path crm:P3_has_note ],
        [ sh:class heritageGraph:Festival ;
            sh:description "Larger festival this ritual is part of" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path crm:P9i_forms_part_of ] ;
    sh:targetClass heritageGraph:LivingGoddessRetirement .

heritageGraph:Metadata a sh:NodeShape ;
    sh:closed true ;
    sh:description "Dataset metadata information" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name of the heritage dataset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path heritageGraph:dataset_name ],
        [ sh:datatype xsd:string ;
            sh:description "License under which the dataset is published (e.g. CC BY 4.0)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path heritageGraph:license ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier of the dataset instance (e.g. semantic version or release date)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path heritageGraph:dataset_version ],
        [ sh:datatype xsd:string ;
            sh:description "Person or institution responsible for curating the dataset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path heritageGraph:curator ],
        [ sh:datatype xsd:string ;
            sh:description "Date the dataset was generated or last exported (ISO 8601)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path heritageGraph:generated_date ],
        [ sh:datatype xsd:string ;
            sh:description "Version of the HeritageGraph schema the dataset conforms to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path heritageGraph:schema_version ] ;
    sh:targetClass heritageGraph:Metadata .

heritageGraph:Murti a sh:NodeShape ;
    sh:closed true ;
    sh:description "Consecrated statue of a deity, ritually activated to serve as divine presence (not merely depiction)" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class crm:E14_Condition_Assessment ;
            sh:description "Condition assessment events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path crm:P34i_was_assessed_by ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path rdfs:label ],
        [ sh:class crm:E10_Transfer_of_Custody ;
            sh:description "Custody transfer events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path crm:P30i_custody_transferred_through ],
        [ sh:class heritageGraph:Consecration ;
            sh:description "Consecration event that activated this murti" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path heritageGraph:consecrated_by_event ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique URI identifier" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dct:identifier ],
        [ sh:class crm:E53_Place ;
            sh:description "Current location of object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path crm:P55_has_current_location ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity depicted iconographically (not cultic presence)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P62_depicts ],
        [ sh:class crm:E12_Production ;
            sh:description "Event that created this object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P108i_was_produced_by ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals in which this structure participates" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path heritageGraph:participates_in_ritual ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity represented and ritually associated with the Murti" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path crm:P129_is_about ],
        [ sh:class crm:E39_Actor ;
            sh:description "Actor(s) who use, handle, or are responsible for this object in ritual contexts" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path heritageGraph:used_by ] ;
    sh:targetClass heritageGraph:Murti .

heritageGraph:Temple a sh:NodeShape ;
    sh:closed true ;
    sh:description "Sacred architectural structure legally classified as an 'Ancient Monument' under Nepal's preservation laws, characterized by deity enshrinement and ritual activation." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Current physical status of the structure" ;
            sh:in ( heritageGraph:Extant heritageGraph:PartiallyExtant heritageGraph:Destroyed heritageGraph:Lost heritageGraph:Hypothetical heritageGraph:Unknown ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path heritageGraph:existence_status ],
        [ sh:class heritageGraph:DataSource ;
            sh:description "Sources that influenced or documented this entity (distinct from assertion derivation via was_derived_from_source)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path prov:wasInfluencedBy ],
        [ sh:description "Architectural style classification" ;
            sh:in ( heritageGraph:Pagoda heritageGraph:Shikhara heritageGraph:Dome heritageGraph:ChaityaStyle heritageGraph:StupaStyle ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path heritageGraph:has_architectural_style ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique URI identifier" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path dct:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:date ;
            sh:description "Latest date when this structure is documented as existing (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path heritageGraph:last_known_existence_date ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path rdfs:label ],
        [ sh:class crm:E53_Place ;
            sh:description "Current location of object or structure" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P55_has_current_location ],
        [ sh:class crm:E25_Architectural_Element ;
            sh:description "Architectural elements composing structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path crm:P46_is_composed_of ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class crm:E14_Condition_Assessment ;
            sh:description "Condition assessment events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path crm:P34i_was_assessed_by ],
        [ sh:class crm:E53_Place ;
            sh:description "Possible locations if the structure is lost" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path heritageGraph:hypothesized_location ],
        [ sh:class heritageGraph:Enshrinement ;
            sh:description "Enshrinement event that installed deity in temple" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path heritageGraph:enshrines_deity_through_event ],
        [ sh:class crm:E10_Transfer_of_Custody ;
            sh:description "Custody transfer events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path crm:P30i_custody_transferred_through ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals in which this structure participates" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path heritageGraph:participates_in_ritual ],
        [ sh:class crm:E12_Production ;
            sh:description "Event that created this object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P108i_was_produced_by ],
        [ sh:class crminf:I2_Belief ;
            sh:description "All factual claims about this structure with full provenance" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path heritageGraph:has_provenance_assertion ],
        [ sh:class crm:E6_Destruction ;
            sh:description "Event that destroyed this structure (if known)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path heritageGraph:destruction_event ] ;
    sh:targetClass heritageGraph:Temple .

crm:E4_Period a sh:NodeShape ;
    sh:closed true ;
    sh:description "Time-bounded role where a person embodies a deity as Living Goddess (Kumari), residing at a specific god-house and supported by religious institutions. This class captures the unique Nepali tradition of living deity embodiment in young girls selected from Buddhist Shakya/Vajracharya families." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E21_Person ;
            sh:description "The girl serving as Living Goddess during this period" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path crm:P11_had_participant ],
        [ sh:class heritageGraph:Guthi ;
            sh:description "Guthi or state body providing economic/ritual support during tenure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path heritageGraph:supported_by_institution ],
        [ sh:class heritageGraph:LivingGoddessRetirement ;
            sh:description "Retirement event that ended this Living Goddess tenure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path heritageGraph:has_retirement_event ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity believed to be present in this person (e.g., Taleju, Kumari Devi)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P14.1_in_the_role_of ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Duration of Living Goddess tenure (from selection to retirement)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class heritageGraph:ArchitecturalStructure ;
            sh:description "God-house where Living Goddess resides (e.g., Kumari Ghar)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path crm:P74_has_current_or_former_residence ],
        [ sh:datatype xsd:string ;
            sh:description "Name of this tenure period (e.g., 'Kumari Samita Bajracharya Tenure 2015-2023')" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:was_documented_by ] ;
    sh:targetClass crm:E4_Period .

time:Calendar a sh:NodeShape ;
    sh:closed true ;
    sh:description "Calendar reckoning system with conversion rules for multi-calendar temporal reasoning" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E55_Type ;
            sh:description "Religious tradition(s) that primarily use this calendar system (e.g., Bikram Sambat for Hindu, Nepal Sambat for Newar Buddhist)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:is_primary_for_tradition ],
        [ sh:datatype xsd:integer ;
            sh:description "Mathematical offset to convert to Common Era (e.g., +57 for BS)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path heritageGraph:year_offset_from_gregorian ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
