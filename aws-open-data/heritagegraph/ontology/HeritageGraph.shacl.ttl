heritageGraph:ArchitecturalStructure a sh:NodeShape ;
    sh:closed true ;
    sh:description "Physical structures built for religious, social, or civic purposes. Links to events of production, use, custody, and documentation." ;
    sh:ignoredProperties ( rdf:type heritageGraph:enshrines_deity_through_event ) ;
    sh:property [ sh:class crm:E25_Architectural_Element ;
            sh:description "Architectural elements composing structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P46_is_composed_of ],
        [ sh:class crm:E14_Condition_Assessment ;
            sh:description "Condition assessment events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P34i_was_assessed_by ],
        [ sh:class crm:E6_Destruction ;
            sh:description "Event that destroyed this structure (if known)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path heritageGraph:destruction_event ],
        [ sh:datatype xsd:date ;
            sh:description "Latest date when this structure is documented as existing (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:last_known_existence_date ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:class crm:E12_Production ;
            sh:description "Event that created this object or structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P108i_was_produced_by ],
        [ sh:class crm:E53_Place ;
            sh:description "Current location of object or structure" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P55_has_current_location ],
        [ sh:description "Architectural style classification" ;
            sh:in ( heritageGraph:Pagoda heritageGraph:Shikhara heritageGraph:Dome heritageGraph:ChaityaStyle heritageGraph:StupaStyle ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path heritageGraph:has_architectural_style ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals in which this structure participates" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path heritageGraph:participates_in_ritual ],
        [ sh:class crm:E10_Transfer_of_Custody ;
            sh:description "Custody transfer events for this structure" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path crm:P30i_custody_transferred_through ],
        [ sh:description "Current physical status of the structure" ;
            sh:in ( heritageGraph:Extant heritageGraph:PartiallyExtant heritageGraph:Destroyed heritageGraph:Lost heritageGraph:Hypothetical heritageGraph:Unknown ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path heritageGraph:existence_status ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:DataSource ;
            sh:description "Sources that influenced or documented this entity (distinct from assertion derivation via was_derived_from_source)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path prov:wasInfluencedBy ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique URI identifier" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dct:identifier ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class crm:E53_Place ;
            sh:description "Possible locations if the structure is lost" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path heritageGraph:hypothesized_location ],
        [ sh:class crminf:I2_Belief ;
            sh:description "All factual claims about this structure with full provenance" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path heritageGraph:has_provenance_assertion ] ;
    sh:targetClass heritageGraph:ArchitecturalStructure .

heritageGraph:InformationObject a sh:NodeShape ;
    sh:closed true ;
    sh:description "A recorded piece of information about heritage" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Type of identifier (DOI, ISBN, Handle, LocalArchiveID)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path datacite:identifierType ],
        [ sh:description "Epistemic standing of a source or assertion (scholarly, community, priestly, uncertain)." ;
            sh:in ( heritageGraph:Scholarly heritageGraph:Community heritageGraph:Priestly heritageGraph:State heritageGraph:SyncreticTradition heritageGraph:Uncertain ) ;
            sh:maxCount 1 ;
            sh:order 17 ;
            sh:path heritageGraph:epistemic_stance ],
        [ sh:datatype xsd:string ;
            sh:description "Language of the source material" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path crm:P72_has_language ],
        [ sh:description "Controlled source-type classification for provenance and epistemic filtering." ;
            sh:in ( heritageGraph:OralHistory heritageGraph:Inscription heritageGraph:FieldSurvey heritageGraph:ArchivalRecordSource heritageGraph:PublishedScholarship heritageGraph:CommunityNarrative heritageGraph:RitualProtocol ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path heritageGraph:source_type ],
        [ sh:datatype xsd:string ;
            sh:description "Event that this information object describes. Range intentionally left open (see is_about_entity): owl:equivalentProperty crm:P129_is_about in the LUX module precludes a narrow rdfs:range here." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path heritageGraph:is_about_event ],
        [ sh:datatype xsd:string ;
            sh:description "Formal citation of source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path heritageGraph:source_citation ],
        [ sh:datatype xsd:string ;
            sh:description "Entity that this information object describes. Range intentionally left open: the LUX alignment module asserts owl:equivalentProperty with the generic crm:P129_is_about, so a narrow rdfs:range would over-constrain P129 and make sibling is_about_* sub-properties unsatisfiable under merged reasoning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path heritageGraph:is_about_entity ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path crm:P3_has_note ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "When source was published" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path heritageGraph:publication_timespan ],
        [ sh:datatype xsd:string ;
            sh:description "Persistent identifier for the source (DOI, archive ID, catalog number)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path datacite:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "URL or digital identifier for source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path heritageGraph:source_url ],
        [ sh:datatype xsd:string ;
            sh:description "Where stored (e.g., National Museum Kathmandu, British Library, URL)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path heritageGraph:archival_location ],
        [ sh:datatype xsd:string ;
            sh:description "Traditional-knowledge access, attribution, or care notice (e.g., community protocol labels)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path heritageGraph:traditional_knowledge_notice ],
        [ sh:datatype xsd:string ;
            sh:description "High-level DataCite resource type (Dataset, Text, Image, Audio, Interview)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path datacite:resourceType ],
        [ sh:class crm:E39_Actor ;
            sh:description "Entity responsible for making the source available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path datacite:publisher ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI of an applied Local Contexts Traditional Knowledge (TK) or Biocultural (BC) Notice or Label." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path heritageGraph:local_contexts_label ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class crm:E39_Actor ;
            sh:description "Person or organization primarily responsible for creating the source" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path datacite:creator ],
        [ sh:datatype xsd:string ;
            sh:description "Community, custodial group, or tradition-bearer attribution for the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path heritageGraph:community_attribution ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation activity that produced this information object" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path prov:wasGeneratedBy ] ;
    sh:targetClass heritageGraph:InformationObject .

crm:E57_Material a sh:NodeShape ;
    sh:closed true ;
    sh:description "Physical substance used in construction or crafting" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ] ;
    sh:targetClass crm:E57_Material .

heritageGraph:CasteGroup a sh:NodeShape ;
    sh:closed true ;
    sh:description "Hereditary social group (Jati) with specific ritual roles and occupational duties" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Hereditary occupation or ritual duty" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path heritageGraph:traditional_role ] ;
    sh:targetClass heritageGraph:CasteGroup .

heritageGraph:Festival a sh:NodeShape ;
    sh:closed true ;
    sh:description "Large-scale community ritual event (Jatra) involving processions, music, and collective participation" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Frequency of recurring ritual (e.g., annual, monthly)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path heritageGraph:recurrence_pattern ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity understood to be manifest through this ritual without equating person and deity identity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path heritageGraph:manifests_divine_presence ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Ritual occurs at specific temple or monument" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P8_took_place_on_or_within ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:class crm:E39_Actor ;
            sh:description "Actor(s) who performed this event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path crm:P14_carried_out_by ],
        [ sh:class crm:E53_Place ;
            sh:description "Starting location of movement ritual" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path heritageGraph:start_place ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Points to the next ritual in the canonical sequence." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path crm:P120_occurs_before ],
        [ sh:class crm:E57_Material ;
            sh:description "Ephemeral materials consumed during the ritual (e.g., oil, rice)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path crm:P125_used_object_of_type ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path crm:P3_has_note ],
        [ sh:class heritageGraph:Guthi ;
            sh:description "Guthi organization managing this structure or ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path heritageGraph:managed_by_guthi ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class crminf:I2_Belief ;
            sh:description "All factual claims about this structure with full provenance" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path heritageGraph:has_provenance_assertion ],
        [ sh:description "Classification of ritual (puja, jatra, consecration)" ;
            sh:in ( heritageGraph:NityaPuja heritageGraph:NaimittikaPuja heritageGraph:KamyaPuja heritageGraph:Abhisheka heritageGraph:Homa heritageGraph:Bhajan heritageGraph:Yagna heritageGraph:Vrata heritageGraph:Jatra heritageGraph:ChariotProcession heritageGraph:MaskedPerformance heritageGraph:RitualConsecration heritageGraph:ProcessionRitual heritageGraph:InstallationRitual heritageGraph:DeinstallationRitual heritageGraph:ReturningRitual heritageGraph:Circumambulation heritageGraph:RelicTour heritageGraph:ProcessionalMovement ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path heritageGraph:ritual_type ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity invoked or made present through ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path heritageGraph:invokes_deity ],
        [ sh:class crm:E53_Place ;
            sh:description "Ordered list of places visited during movement ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path heritageGraph:route_places ],
        [ sh:class crm:E53_Place ;
            sh:description "Ending location of movement ritual" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path heritageGraph:end_place ],
        [ sh:datatype xsd:string ;
            sh:description "Text description of the procession route" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path heritageGraph:route_description ],
        [ sh:datatype xsd:string ;
            sh:description "Lunar day (Tithi) for ritual timing" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path heritageGraph:lunar_date_tithi ],
        [ sh:class heritageGraph:Festival ;
            sh:description "Larger festival this ritual is part of" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path crm:P9i_forms_part_of ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Component rituals of festival" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path crm:P9_consists_of ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:description "Group (Guthi, caste) responsible for ritual" ;
            sh:or ( [ sh:class heritageGraph:Guthi ] [ sh:class heritageGraph:CasteGroup ] ) ;
            sh:order 11 ;
            sh:path heritageGraph:performed_by_group ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Points to the prerequisite ritual." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path crm:P120i_is_occurred_before_by ] ;
    sh:targetClass heritageGraph:Festival .

crm:E21_Person a sh:NodeShape ;
    sh:closed true ;
    sh:description "Individual person who performs, commissions, documents, or verifies heritage activities" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E52_Time-Span ;
            sh:description "Person's death timespan" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path heritageGraph:death_timespan ],
        [ sh:class heritageGraph:Guthi ;
            sh:description "Groups this person belongs to" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path crm:P107i_is_current_or_former_member_of ],
        [ sh:datatype xsd:anyURI ;
            sh:description "ORCID persistent identifier URI for a researcher or documented contributor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path heritageGraph:orcid_identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Institutional affiliation (e.g., Tribhuvan University, Nepal Heritage Society)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:institutional_affiliation ],
        [ sh:class heritageGraph:HeritageEvent ;
            sh:description "Activities performed by this actor" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:carried_out_activity ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Person's birth timespan" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path heritageGraph:birth_timespan ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Areas of expertise (e.g., Lichhavi inscriptions, Sanskrit epigraphy, Newari archaeology)" ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path heritageGraph:expertise_area ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique URI identifier" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dct:identifier ] ;
    sh:targetClass crm:E21_Person .

crm:E6_Destruction a sh:NodeShape ;
    sh:closed true ;
    sh:description "Event that destroyed or damaged a structure." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path crm:P3_has_note ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class crm:E53_Place ;
            sh:description "Place where event occurred" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P7_took_place_at ],
        [ sh:class heritageGraph:ArchitecturalStructure ;
            sh:description "Heritage structures affected by or present during this historical event" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path crm:P12_occurred_in_the_presence_of ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Component rituals of festival" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P9_consists_of ] ;
    sh:targetClass crm:E6_Destruction .

crm:E25_Architectural_Element a sh:NodeShape ;
    sh:closed true ;
    sh:description "Carved or constructed component of an architectural structure (e.g., Gajur, Torana, Tundal)" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:ArchitecturalStructure ;
            sh:description "Larger structure that this element is part of" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path crm:P46i_forms_part_of ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ] ;
    sh:targetClass crm:E25_Architectural_Element .

crm:E14_Condition_Assessment a sh:NodeShape ;
    sh:closed true ;
    sh:description "Event of evaluating the physical state of a heritage object or structure" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E39_Actor ;
            sh:description "Actor(s) who performed this event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P14_carried_out_by ],
        [ sh:class crm:E3_Condition_State ;
            sh:description "Condition state identified by the assessment" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P35_has_identified ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Object assessed for condition" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path crm:P34_concerned ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P4_has_time-span ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ] ;
    sh:targetClass crm:E14_Condition_Assessment .

heritageGraph:DataSource a sh:NodeShape ;
    sh:closed true ;
    sh:description "Original source from which heritage information was derived" ;
    sh:ignoredProperties ( rdf:type prov:wasGeneratedBy heritageGraph:was_documented_by heritageGraph:is_about_entity heritageGraph:derived_from_interview heritageGraph:is_about_event ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Community, custodial group, or tradition-bearer attribution for the source." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path heritageGraph:community_attribution ],
        [ sh:class crm:E39_Actor ;
            sh:description "Entity responsible for making the source available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path datacite:publisher ],
        [ sh:datatype xsd:string ;
            sh:description "Traditional-knowledge access, attribution, or care notice (e.g., community protocol labels)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path heritageGraph:traditional_knowledge_notice ],
        [ sh:datatype xsd:string ;
            sh:description "Type of identifier (DOI, ISBN, Handle, LocalArchiveID)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path datacite:identifierType ],
        [ sh:datatype xsd:string ;
            sh:description "URL or digital identifier for source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:source_url ],
        [ sh:description "Controlled source-type classification for provenance and epistemic filtering." ;
            sh:in ( heritageGraph:OralHistory heritageGraph:Inscription heritageGraph:FieldSurvey heritageGraph:ArchivalRecordSource heritageGraph:PublishedScholarship heritageGraph:CommunityNarrative heritageGraph:RitualProtocol ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path heritageGraph:source_type ],
        [ sh:datatype xsd:string ;
            sh:description "Language of the source material" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path crm:P72_has_language ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI of an applied Local Contexts Traditional Knowledge (TK) or Biocultural (BC) Notice or Label." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path heritageGraph:local_contexts_label ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Persistent identifier for the source (DOI, archive ID, catalog number)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path datacite:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "High-level DataCite resource type (Dataset, Text, Image, Audio, Interview)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path datacite:resourceType ],
        [ sh:datatype xsd:string ;
            sh:description "Where stored (e.g., National Museum Kathmandu, British Library, URL)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path heritageGraph:archival_location ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "When source was published" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path heritageGraph:publication_timespan ],
        [ sh:class crm:E39_Actor ;
            sh:description "Person or organization primarily responsible for creating the source" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path datacite:creator ],
        [ sh:description "Epistemic standing of a source or assertion (scholarly, community, priestly, uncertain)." ;
            sh:in ( heritageGraph:Scholarly heritageGraph:Community heritageGraph:Priestly heritageGraph:State heritageGraph:SyncreticTradition heritageGraph:Uncertain ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path heritageGraph:epistemic_stance ],
        [ sh:datatype xsd:string ;
            sh:description "Formal citation of source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path heritageGraph:source_citation ] ;
    sh:targetClass heritageGraph:DataSource .

crm:E10_Transfer_of_Custody a sh:NodeShape ;
    sh:closed true ;
    sh:description "Event of transferring responsibility for temple maintenance, ritual performance, or artifact stewardship" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crm:E39_Actor ;
            sh:description "New custodian (person or group)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P29_custody_received_by ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class crm:E53_Place ;
            sh:description "Place where event occurred" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P7_took_place_at ],
        [ sh:class crm:E39_Actor ;
            sh:description "Previous custodian" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P28_custody_surrendered_by ],
        [ sh:class heritageGraph:Guthi ;
            sh:description "New custodian (Guthi)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path heritageGraph:transferred_to_guthi ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Object transferred in custody event" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path crm:P30_transferred_custody_of ] ;
    sh:targetClass crm:E10_Transfer_of_Custody .

crm:E12_Production a sh:NodeShape ;
    sh:closed true ;
    sh:description "Event of creating an architectural structure, murti, or paubha" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crminf:I2_Belief ;
            sh:description "All factual claims about this structure with full provenance" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path heritageGraph:has_provenance_assertion ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Object produced by this production event" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path crm:P108_has_produced ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class crm:E53_Place ;
            sh:description "Place where event occurred" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P7_took_place_at ],
        [ sh:class crm:E39_Actor ;
            sh:description "Actor(s) who performed this event" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path crm:P14_carried_out_by ],
        [ sh:class crm:E39_Actor ;
            sh:description "Person or group who commissioned production" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path crm:P17_was_motivated_by ],
        [ sh:class crm:E29_Design_or_Procedure ;
            sh:description "Craft technique used in production" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P32_used_general_technique ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path crm:P4_has_time-span ] ;
    sh:targetClass crm:E12_Production .

heritageGraph:PhysicalHeritageThing a sh:NodeShape ;
    sh:closed true ;
    sh:description "Union of tangible heritage object classes: structures, iconographic objects, and architectural elements." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass heritageGraph:PhysicalHeritageThing .

heritageGraph:Guthi a sh:NodeShape ;
    sh:closed true ;
    sh:description "Endowed trust organization unique to Nepal, managing temples, rituals, and land through hereditary or voluntary membership" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:class crm:E21_Person ;
            sh:description "Members of Guthi organization" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path crm:P107_has_current_or_former_member ],
        [ sh:class heritageGraph:ArchitecturalStructure ;
            sh:description "Structures under Guthi custodianship" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path crm:P50_has_current_keeper ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals performed by this Guthi" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path heritageGraph:performs_ritual ],
        [ sh:description "Type of Guthi (Si, Jatra, Temple)" ;
            sh:in ( heritageGraph:SiGuthi heritageGraph:JatraGuthi heritageGraph:PujaGuthi heritageGraph:TempleGuthi heritageGraph:NashaGuthi heritageGraph:SanaGuthi heritageGraph:SanGuthi heritageGraph:RajGuthi ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path heritageGraph:guthi_type ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ] ;
    sh:targetClass heritageGraph:Guthi .

crm:E28_Conceptual_Object a sh:NodeShape ;
    sh:closed true ;
    sh:description "Divine conceptual entity in Hindu, Buddhist, or syncretic traditions. Distinct from physical representations (Murti) and ritual presences." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class heritageGraph:RitualEvent ;
            sh:description "Rituals where this deity is invoked" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path heritageGraph:is_invoked_in_ritual ],
        [ sh:class crm:E55_Type ;
            sh:description "Religious tradition(s) within which this deity is venerated" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:has_religious_tradition ],
        [ sh:class heritageGraph:Enshrinement ;
            sh:description "Events where this deity was enshrined" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path heritageGraph:is_enshrined_through_event ],
        [ sh:class heritageGraph:IconographicObject ;
            sh:description "Iconographic objects that depict this deity" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path crm:P62i_is_depicted_by ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ] ;
    sh:targetClass crm:E28_Conceptual_Object .

crm:E39_Actor a sh:NodeShape ;
    sh:closed true ;
    sh:description "General actor (person or group) responsible for events" ;
    sh:ignoredProperties ( rdf:type heritageGraph:expertise_area heritageGraph:institutional_affiliation dct:identifier heritageGraph:death_timespan heritageGraph:birth_timespan crm:P107i_is_current_or_former_member_of heritageGraph:orcid_identifier ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:class heritageGraph:HeritageEvent ;
            sh:description "Activities performed by this actor" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:carried_out_activity ] ;
    sh:targetClass crm:E39_Actor .

crm:E52_Time-Span a sh:NodeShape ;
    sh:closed true ;
    sh:description "Temporal extent of an event or period" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The level of precision for a recorded date." ;
            sh:in ( heritageGraph:Exact heritageGraph:Year heritageGraph:Decade heritageGraph:Century heritageGraph:Circa ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path heritageGraph:date_precision ],
        [ sh:datatype xsd:date ;
            sh:description "Latest possible date (for uncertain dates)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P82b_end_of_the_end ],
        [ sh:class time:Calendar ;
            sh:description "Calendar system used for date representation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:calendar_system ],
        [ sh:datatype xsd:date ;
            sh:description "Earliest possible date (for uncertain dates)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path crm:P82a_begin_of_the_begin ] ;
    sh:targetClass crm:E52_Time-Span .

crminf:I2_Belief a sh:NodeShape ;
    sh:closed true ;
    sh:description "A single factual claim about a heritage entity, with explicit source, author, date, and confidence" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class crminf:I2_Belief ;
            sh:description "Previous version of this assertion (if this is an update). Creates version chain: A1 → A2 → A3. Query pattern: latest assertion = one with no incoming prov:wasRevisionOf" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path prov:wasRevisionOf ],
        [ sh:datatype xsd:string ;
            sh:description "The factual claim being asserted" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path prov:value ],
        [ sh:datatype xsd:string ;
            sh:description "Status of multi-source reconciliation (confirmed, conflicting, unverified)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path heritageGraph:reconciliation_status ],
        [ sh:datatype xsd:string ;
            sh:description "Optional value claimed for asserted_property when using structured property-value assertions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path heritageGraph:asserted_value ],
        [ sh:description "Epistemic standing of a source or assertion (scholarly, community, priestly, uncertain)." ;
            sh:in ( heritageGraph:Scholarly heritageGraph:Community heritageGraph:Priestly heritageGraph:State heritageGraph:SyncreticTradition heritageGraph:Uncertain ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path heritageGraph:epistemic_stance ],
        [ sh:datatype xsd:dateTime ;
            sh:description "When this assertion was recorded (ISO 8601)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path prov:generatedAtTime ],
        [ sh:datatype xsd:string ;
            sh:description "Optional property or attribute name when the assertion is structured as a property-value pair." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path heritageGraph:asserted_property ],
        [ sh:class crm:E21_Person ;
            sh:description "Person who made this assertion" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path prov:wasAttributedTo ],
        [ sh:datatype xsd:float ;
            sh:description "Reliability score for assertion (0.0-1.0)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path heritageGraph:confidence_score ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Event that is the subject of this belief/assertion (CRMinf I2_Belief scope; not an E13 attribute assignment)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:asserts_about_event ],
        [ sh:class crminf:I2_Belief ;
            sh:description "Other assertions that contest or contradict this claim, supporting multi-vocal heritage representation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path heritageGraph:conflicts_with_assertion ],
        [ sh:class crm:E1_CRM_Entity ;
            sh:description "Entity that is the subject of this belief/assertion (CRMinf I2_Belief scope; not an E13 attribute assignment)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path heritageGraph:asserts_about_entity ],
        [ sh:class heritageGraph:DataSource ;
            sh:description "Source(s) from which this assertion was derived" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path prov:wasDerivedFrom ],
        [ sh:datatype xsd:string ;
            sh:description "Notes on data quality, completeness, or uncertainty" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path heritageGraph:data_quality_note ] ;
    sh:targetClass crminf:I2_Belief .

heritageGraph:DocumentationActivity a sh:NodeShape ;
    sh:closed true ;
    sh:description "The intellectual or technical process of recording information about a heritage entity, aligned with CIDOC E7 Activity and PROV-O Activity." ;
    sh:ignoredProperties ( crm:P3_has_note rdf:type heritageGraph:verified_by_expert heritageGraph:verified_assertion heritageGraph:verification_method ) ;
    sh:property [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Heritage entity documented by this activity (documentation subject, not E13 assignment target)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path heritageGraph:subject_entity ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class heritageGraph:InformationObject ;
            sh:description "Information object (record, document) produced by documentation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path prov:generated ],
        [ sh:datatype xsd:string ;
            sh:description "Documentation method used (free-text). Not mapped to crm:P33_used_specific_technique, which is an object property requiring an crm:E29 technique resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path heritageGraph:used_method ],
        [ sh:class crminf:I2_Belief ;
            sh:description "Assertions generated by documentation activity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:generated_assertion ],
        [ sh:datatype xsd:string ;
            sh:description "Equipment used in documentation (free-text). Not mapped to crm:P16_used_specific_object, which is an object property requiring an crm:E70 thing resource." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path heritageGraph:used_equipment ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Event documented by this activity (documentation subject, not E13 assignment target)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path heritageGraph:subject_event ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class crm:E21_Person ;
            sh:description "Agent who performed documentation" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path prov:wasAssociatedWith ] ;
    sh:targetClass heritageGraph:DocumentationActivity .

heritageGraph:RitualEvent a sh:NodeShape ;
    sh:closed true ;
    sh:description "Intentional ritual activity that activates sacred space, invokes deities, and binds social groups" ;
    sh:ignoredProperties ( heritageGraph:ended_tenure_of rdf:type crm:P7_took_place_at heritageGraph:makes_deity_present heritageGraph:consecrated_object heritageGraph:initiated_tenure crm:P9_consists_of heritageGraph:selection_criteria_met heritageGraph:enshrined_deity heritageGraph:enshrined_in_structure heritageGraph:selected_person heritageGraph:is_critical_for_festival ) ;
    sh:property [ sh:class heritageGraph:Guthi ;
            sh:description "Guthi organization managing this structure or ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path heritageGraph:managed_by_guthi ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text note (description, reason, verification notes)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path crm:P3_has_note ],
        [ sh:description "Group (Guthi, caste) responsible for ritual" ;
            sh:or ( [ sh:class heritageGraph:Guthi ] [ sh:class heritageGraph:CasteGroup ] ) ;
            sh:order 10 ;
            sh:path heritageGraph:performed_by_group ],
        [ sh:class heritageGraph:DocumentationActivity ;
            sh:description "Documentation event that recorded this entity or event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path heritageGraph:was_documented_by ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Points to the prerequisite ritual." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path crm:P120i_is_occurred_before_by ],
        [ sh:class crm:E52_Time-Span ;
            sh:description "Links event to its temporal extent" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path crm:P4_has_time-span ],
        [ sh:class crm:E53_Place ;
            sh:description "Starting location of movement ritual" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path heritageGraph:start_place ],
        [ sh:class crminf:I2_Belief ;
            sh:description "All factual claims about this structure with full provenance" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path heritageGraph:has_provenance_assertion ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Ritual occurs at specific temple or monument" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P8_took_place_on_or_within ],
        [ sh:datatype xsd:string ;
            sh:description "Lunar day (Tithi) for ritual timing" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path heritageGraph:lunar_date_tithi ],
        [ sh:datatype xsd:string ;
            sh:description "Text description of the procession route" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path heritageGraph:route_description ],
        [ sh:description "Classification of ritual (puja, jatra, consecration)" ;
            sh:in ( heritageGraph:NityaPuja heritageGraph:NaimittikaPuja heritageGraph:KamyaPuja heritageGraph:Abhisheka heritageGraph:Homa heritageGraph:Bhajan heritageGraph:Yagna heritageGraph:Vrata heritageGraph:Jatra heritageGraph:ChariotProcession heritageGraph:MaskedPerformance heritageGraph:RitualConsecration heritageGraph:ProcessionRitual heritageGraph:InstallationRitual heritageGraph:DeinstallationRitual heritageGraph:ReturningRitual heritageGraph:Circumambulation heritageGraph:RelicTour heritageGraph:ProcessionalMovement ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path heritageGraph:ritual_type ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity understood to be manifest through this ritual without equating person and deity identity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path heritageGraph:manifests_divine_presence ],
        [ sh:class crm:E53_Place ;
            sh:description "Ending location of movement ritual" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path heritageGraph:end_place ],
        [ sh:class heritageGraph:RitualEvent ;
            sh:description "Points to the next ritual in the canonical sequence." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path crm:P120_occurs_before ],
        [ sh:class heritageGraph:Festival ;
            sh:description "Larger festival this ritual is part of" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path crm:P9i_forms_part_of ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ],
        [ sh:class crm:E53_Place ;
            sh:description "Ordered list of places visited during movement ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path heritageGraph:route_places ],
        [ sh:datatype xsd:string ;
            sh:description "Frequency of recurring ritual (e.g., annual, monthly)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path heritageGraph:recurrence_pattern ],
        [ sh:class crm:E28_Conceptual_Object ;
            sh:description "Deity invoked or made present through ritual" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path heritageGraph:invokes_deity ],
        [ sh:class crm:E57_Material ;
            sh:description "Ephemeral materials consumed during the ritual (e.g., oil, rice)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path crm:P125_used_object_of_type ],
        [ sh:class crm:E39_Actor ;
            sh:description "Actor(s) who performed this event" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path crm:P14_carried_out_by ] ;
    sh:targetClass heritageGraph:RitualEvent .

crm:E53_Place a sh:NodeShape ;
    sh:closed true ;
    sh:description "Defined geographic location where events occur and structures exist" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype geo:wktLiteral ;
            sh:description "Coordinates as WKT literal" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path geo:asWKT ],
        [ sh:datatype xsd:string ;
            sh:description "Type of place (city, village, region)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path heritageGraph:place_type ],
        [ sh:class heritageGraph:PhysicalHeritageThing ;
            sh:description "Structures located in this place" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path crm:P53i_is_former_or_current_location_of ],
        [ sh:datatype xsd:string ;
            sh:description "Primary name or label" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path rdfs:label ] ;
    sh:targetClass crm:E53_Place .


